# Normalize line endings on commit; keep native in working tree.
* text=auto

# Scripts that must keep LF (run inside Linux Docker containers)
*.sh        text eol=lf
*.py        text eol=lf
Dockerfile* text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.sql       text eol=lf
*.conf      text eol=lf
*.xml       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.css       text eol=lf
*.md        text eol=lf

# Windows-only scripts keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary assets
*.docx      binary
*.pptx      binary
*.xlsx      binary
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
