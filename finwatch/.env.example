# ============================================
# FinWatch Environment Variables
# ============================================
#
# Example credentials for local Docker only. The values below are the
# defaults the demo stack ships with so `docker compose up -d` works
# out-of-box on a developer laptop. They are NOT secret and MUST be
# replaced before any non-localhost deployment.
#
# Production deployments should source these from a secrets manager
# (HashiCorp Vault, AWS Secrets Manager, k8s Secrets) — never commit a
# .env file with production values.
#
# Copy to `.env` once: `cp .env.example .env`
# ============================================

# PostgreSQL
POSTGRES_DB=finwatch
POSTGRES_USER=finwatch
POSTGRES_PASSWORD=finwatch_secret_2024
POSTGRES_PORT=5432

# Debezium
DEBEZIUM_USER=debezium
DEBEZIUM_PASSWORD=debezium_secret_2024
CONNECT_REST_PORT=8083

# Kafka
KAFKA_BROKER_PORT=9092
KAFKA_BROKER_EXTERNAL_PORT=29092

# ClickHouse
CLICKHOUSE_DB=finwatch
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_secret_2024
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus
PROMETHEUS_PORT=9090

# FinWatch Web UI (live demo dashboard)
WEB_PORT=3002
